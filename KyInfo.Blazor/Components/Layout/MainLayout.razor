@inherits LayoutComponentBase
@rendermode InteractiveServer
@implements IDisposable
@inject NavigationManager Navigation

<div class="page app-shell">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="app-main">
        <header class="app-header">
            <div class="app-header-left">
                <div class="app-header-kicker">KyInfo</div>
                <div>
                    <div class="app-title">@AppTitle</div>
                    <div class="app-subtitle">@AppSubtitle</div>
                </div>
            </div>
            <div class="app-header-meta">
                @if (string.IsNullOrWhiteSpace(userName))
                {
                    <div class="app-user-pill" title="当前登录用户">
                        <span class="bi bi-person-circle app-user-pill-icon" aria-hidden="true"></span>
                        <span class="app-user-pill-label">@DisplayUserName</span>
                    </div>
                }
                else
                {
                    <a class="app-user-pill app-user-pill-link" href="account" title="打开我的账户">
                        <span class="bi bi-person-circle app-user-pill-icon" aria-hidden="true"></span>
                        <span class="app-user-pill-label">@DisplayUserName</span>
                    </a>
                }
            </div>
        </header>

        <section class="app-content">
            <div class="app-content-inner">
                @Body
            </div>
        </section>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">X</a>
</div>

@code {
    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    [Inject]
    private KyInfo.Blazor.Auth.TokenStore TokenStore { get; set; } = default!;

    private string? userName;
    private string routeKey = string.Empty;

    private string DisplayUserName => string.IsNullOrWhiteSpace(userName) ? "未登录" : userName!;

    private string AppTitle => ResolveAppTitle(routeKey);

    private string AppSubtitle => ResolveAppSubtitle(routeKey);

    protected override void OnInitialized()
    {
        routeKey = GetRouteKeyFromLocation(Navigation.Uri);
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override void OnParametersSet()
    {
        SyncRouteFromNavigation();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var previousRoute = routeKey;
        SyncRouteFromNavigation();
        var routeChanged = !string.Equals(previousRoute, routeKey, StringComparison.Ordinal);

        string? nextUser = TokenStore.UserName;
        if (string.IsNullOrWhiteSpace(nextUser))
        {
            try
            {
                var auth = await JS.InvokeAsync<KyInfo.Blazor.Auth.BrowserAuthResult>("kyinfoAuth.getSession");
                if (auth.Session?.IsAuthenticated == true &&
                    !string.IsNullOrWhiteSpace(auth.Session.Token))
                {
                    TokenStore.SetAuthenticated(
                        auth.Session.Token,
                        auth.Session.UserName,
                        auth.Session.Role,
                        auth.Session.UserId);
                }
                else if (auth.Session?.IsAuthenticated == true &&
                    auth.Session.UserId.HasValue &&
                    !string.IsNullOrWhiteSpace(auth.Session.UserName) &&
                    !string.IsNullOrWhiteSpace(auth.Session.Role))
                {
                    TokenStore.SetProfile(
                        auth.Session.UserId.Value,
                        auth.Session.UserName,
                        auth.Session.Role);
                }
                else if (auth.Session?.IsAuthenticated != true)
                {
                    TokenStore.Clear();
                }
            }
            catch
            {
                // Auth fetch may not be ready during hydration.
            }

            nextUser = TokenStore.UserName;
        }

        var userChanged = !string.Equals(nextUser, userName, StringComparison.Ordinal);
        if (userChanged)
        {
            userName = nextUser;
        }

        if (routeChanged || userChanged)
        {
            StateHasChanged();
        }
    }

    private void SyncRouteFromNavigation()
    {
        var next = GetRouteKeyFromLocation(Navigation.Uri);
        if (!string.Equals(next, routeKey, StringComparison.Ordinal))
        {
            routeKey = next;
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        routeKey = GetRouteKeyFromLocation(e.Location);
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private static string GetRouteKeyFromLocation(string location)
    {
        if (string.IsNullOrWhiteSpace(location))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(location, UriKind.Absolute, out var absolute))
        {
            return FirstPathSegment(absolute.AbsolutePath);
        }

        var trimmed = location.TrimStart('/').Split('?', 2)[0].TrimEnd('/');
        return FirstPathSegment("/" + trimmed);
    }

    private static string FirstPathSegment(string absolutePath)
    {
        var trimmed = absolutePath.Trim('/').Split('?', 2)[0];
        if (string.IsNullOrEmpty(trimmed))
        {
            return string.Empty;
        }

        var segments = trimmed.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return segments.Length > 0 ? segments[0].ToLowerInvariant() : string.Empty;
    }

    private static string ResolveAppTitle(string key) => key switch
    {
        "" => "考研信息系统",
        "account" => "我的档案",
        "admin" => "管理后台",
        "schools" => "院校查询",
        "majors" => "专业查询",
        "scorelines" => "分数线查询",
        "scoreline-trends" => "分数线趋势",
        "recommendations" => "智能志愿推荐",
        "ai-chat" => "AI 助手",
        "recruitinfos" => "招生简章",
        "login" => "登录",
        "register" => "注册",
        _ => "考研信息系统"
    };

    private static string ResolveAppSubtitle(string key) => key switch
    {
        "" => "院校、专业、分数线与志愿推荐，一站式查询与决策辅助",
        "account" => "资料、密码与本人成绩维护",
        "admin" => "用户管理与 Excel 批量导入",
        "schools" => "检索院校信息",
        "majors" => "检索专业信息",
        "scorelines" => "历年分数线检索",
        "scoreline-trends" => "分数线变化趋势",
        "recommendations" => "智能志愿推荐",
        "ai-chat" => "对话式辅助",
        "recruitinfos" => "招生简章检索",
        "login" => "登录以使用完整功能",
        "register" => "注册新账户",
        _ => "院校、专业、分数线与志愿推荐，一站式查询与决策辅助"
    };
}
