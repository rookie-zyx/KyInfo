@using Microsoft.AspNetCore.Components.Routing
@using KyInfo.Blazor.Auth
@implements IDisposable

<div class="top-row ps-3 pe-2 navbar navbar-dark">
    <div class="container-fluid d-flex align-items-center justify-content-between flex-nowrap gap-2">
        <a class="navbar-brand mb-0" href="">KyInfo</a>
        <span class="nav-brand-caption">菜单</span>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        @if (isLoggedIn)
        {
            @if (isAdmin)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin" Match="NavLinkMatch.Prefix">
                        <span class="bi bi-shield-lock" aria-hidden="true"></span> 管理后台
                    </NavLink>
                </div>
            }
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/account" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-person-circle" aria-hidden="true"></span> 我的档案
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="schools" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-building" aria-hidden="true"></span> 院校查询
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="majors" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-journal-text" aria-hidden="true"></span> 专业查询
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="scorelines" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-graph-up" aria-hidden="true"></span> 分数线
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="scoreline-trends" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-bar-chart-line" aria-hidden="true"></span> 分数线趋势
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="recommendations" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-stars" aria-hidden="true"></span> 智能志愿推荐
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="ai-chat" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-chat-dots" aria-hidden="true"></span> AI 助手
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="recruitinfos" Match="NavLinkMatch.Prefix">
                    <span class="bi bi-file-text" aria-hidden="true"></span> 招生简章
                </NavLink>
            </div>
            <div class="nav-item px-3 mt-3">
                <button class="nav-link btn btn-link text-start w-100" type="button" @onclick="Logout">
                    <span class="bi bi-box-arrow-right" aria-hidden="true"></span> 退出登录
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3 mt-3">
                <NavLink class="nav-link" href="login" Match="NavLinkMatch.All">
                    <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> 登录
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="register" Match="NavLinkMatch.All">
                    <span class="bi bi-person-plus" aria-hidden="true"></span> 注册
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    [Inject]
    private TokenStore TokenStore { get; set; } = default!;

    [Inject]
    private KyInfo.Blazor.ApiClient.AccountApiClient AccountApi { get; set; } = default!;

    private bool isLoggedIn;
    private bool isAdmin;
    private string? lastTokenChecked;
    private DateTimeOffset lastProfileFetchUtc = DateTimeOffset.MinValue;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            var auth = await JS.InvokeAsync<BrowserAuthResult>("kyinfoAuth.getSession");
            if (auth.Session?.IsAuthenticated != true)
            {
                TokenStore.Clear();
            }
            else if (!string.IsNullOrWhiteSpace(auth.Session.Token))
            {
                TokenStore.SetAuthenticated(
                    auth.Session.Token,
                    auth.Session.UserName,
                    auth.Session.Role,
                    auth.Session.UserId);
            }
            else if (auth.Session.UserId.HasValue &&
                     !string.IsNullOrWhiteSpace(auth.Session.UserName) &&
                     !string.IsNullOrWhiteSpace(auth.Session.Role))
            {
                TokenStore.SetProfile(
                    auth.Session.UserId.Value,
                    auth.Session.UserName,
                    auth.Session.Role);
            }

            var token = TokenStore.Token;
            var role = TokenStore.Role;
            if (auth.Session?.IsAuthenticated == true &&
                !string.IsNullOrWhiteSpace(token) &&
                !string.Equals(token, lastTokenChecked, StringComparison.Ordinal) &&
                (DateTimeOffset.UtcNow - lastProfileFetchUtc).TotalSeconds >= 2)
            {
                lastProfileFetchUtc = DateTimeOffset.UtcNow;
                try
                {
                    var me = await AccountApi.GetMeAsync();
                    TokenStore.SetProfile(me.Id, me.UserName, me.Role);
                    role = me.Role;
                    lastTokenChecked = token;
                }
                catch
                {
                    // Keep current in-memory state as a fallback and retry later.
                }
            }

            var nextLoggedIn = auth.Session?.IsAuthenticated == true;
            var nextAdmin = nextLoggedIn && AdminAreaRoles.IsStaff(role);
            if (nextLoggedIn != isLoggedIn || nextAdmin != isAdmin)
            {
                isLoggedIn = nextLoggedIn;
                isAdmin = nextAdmin;
                StateHasChanged();
            }
        }
        catch
        {
            // Browser auth fetch may be temporarily unavailable during hydration.
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        try
        {
            await JS.InvokeAsync<BrowserAuthResult>("kyinfoAuth.logout");
        }
        catch
        {
            // Ignore logout transport failures.
        }

        TokenStore.Clear();
        lastTokenChecked = null;
        isLoggedIn = false;
        isAdmin = false;
        StateHasChanged();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

}
