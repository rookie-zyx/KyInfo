@page "/account"
@using KyInfo.Contracts.Account
@using KyInfo.Contracts.ExamScores
@using KyInfo.Blazor.ApiClient
@inject AccountApiClient AccountApi
@inject ExamScoresApiClient ExamScoresApi
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject KyInfo.Blazor.Auth.TokenStore TokenStore

<PageTitle>我的账户 - KyInfo</PageTitle>

<RequireLogin>
    <div class="section-header">
        <div class="section-header-title">
            <h1>我的档案</h1>
            <span class="pill-badge">账号与成绩一体化</span>
        </div>
        <div class="text-muted small section-tagline">
            在一个模块内查看并更新账号信息，同时维护当前账号关联的考研成绩。
        </div>
    </div>

    @if (!string.IsNullOrEmpty(bannerError))
    {
        <div class="alert alert-danger" role="alert">@bannerError</div>
    }
    @if (!string.IsNullOrEmpty(bannerSuccess))
    {
        <div class="alert alert-success" role="alert">@bannerSuccess</div>
    }

    @if (loadError is not null)
    {
        <div class="alert alert-warning" role="alert">@loadError</div>
    }
    else if (profile is null && loadingProfile)
    {
        <p class="text-muted">正在加载账户信息…</p>
    }
    else if (profile is not null)
    {
        <div class="row g-3">
            <div class="col-lg-6">
                <div class="card card-soft h-100">
                    <div class="card-header card-soft-header">
                        <strong>基本资料</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-2 text-muted small">注册时间（UTC）：@profile.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                        <div class="mb-2 text-muted small">角色：<span class="pill-badge pill-badge-muted">@profile.Role</span></div>
                        @if (IsRootProfile)
                        {
                            <p class="small text-muted">Root 账号的用户名与邮箱不可修改，仅可在右侧修改密码。</p>
                        }
                        <div class="mb-3">
                            <label class="form-label small text-muted">用户名</label>
                            <input class="form-control" @bind="editUserName" @bind:event="oninput" maxlength="64" disabled="@IsRootProfile" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">邮箱</label>
                            <input class="form-control" type="email" @bind="editEmail" @bind:event="oninput" maxlength="256" disabled="@IsRootProfile" />
                        </div>
                        <button type="button" class="btn btn-primary" disabled="@(savingProfile || IsRootProfile)" @onclick="SaveProfileAsync">
                            @(savingProfile ? "保存中…" : "保存资料")
                        </button>
                        @if (!string.IsNullOrEmpty(profileMessage))
                        {
                            <span class="ms-2 small @(profileOk ? "text-success" : "text-danger")">@profileMessage</span>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card card-soft h-100">
                    <div class="card-header card-soft-header">
                        <strong>修改密码</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small text-muted">当前密码</label>
                            <input class="form-control" type="password" autocomplete="current-password" @bind="currentPassword" @bind:event="oninput" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">新密码（至少 6 位）</label>
                            <input class="form-control" type="password" autocomplete="new-password" @bind="newPassword" @bind:event="oninput" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">确认新密码</label>
                            <input class="form-control" type="password" autocomplete="new-password" @bind="confirmPassword" @bind:event="oninput" />
                        </div>
                        <button type="button" class="btn btn-outline-primary" disabled="@savingPassword" @onclick="ChangePasswordAsync">
                            @(savingPassword ? "提交中…" : "更新密码")
                        </button>
                        @if (!string.IsNullOrEmpty(passwordMessage))
                        {
                            <span class="ms-2 small @(passwordOk ? "text-success" : "text-danger")">@passwordMessage</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-12">
                <div class="card card-soft">
                    <div class="card-header card-soft-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <strong>我的成绩</strong>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <input class="form-control form-control-sm"
                                   style="width: 120px;"
                                   placeholder="年份筛选"
                                   @bind="scoreYearText" />
                            <button type="button" class="btn btn-sm btn-outline-primary" disabled="@loadingScores" @onclick="ReloadScoresAsync">
                                @(loadingScores ? "加载中…" : "刷新")
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-3">
                            以下数据按当前登录账号的用户 Id（<strong>@profile.Id</strong>）查询。
                        </p>
                        <div class="row g-2 mb-3">
                            <div class="col-md-3">
                                <label class="form-label small text-muted">年份 *</label>
                                <input class="form-control form-control-sm" @bind="newScoreYear" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-muted">总分 *</label>
                                <input class="form-control form-control-sm" @bind="newScoreTotal" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-muted">院校 Id（可选）</label>
                                <input class="form-control form-control-sm" @bind="newScoreSchoolId" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-muted">专业 Id（可选）</label>
                                <input class="form-control form-control-sm" @bind="newScoreMajorId" />
                            </div>
                        </div>
                        <div class="mb-3 d-flex align-items-center gap-2">
                            <button type="button" class="btn btn-sm btn-success" disabled="@savingScore" @onclick="CreateScoreAsync">
                                @(savingScore ? "保存中…" : "新增成绩")
                            </button>
                            @if (!string.IsNullOrWhiteSpace(scoreMessage))
                            {
                                <span class="small @(scoreMessageOk ? "text-success" : "text-danger")">@scoreMessage</span>
                            }
                        </div>
                        @if (loadingScores)
                        {
                            <p class="text-muted small mb-0">正在加载成绩…</p>
                        }
                        else if (!string.IsNullOrEmpty(scoresError))
                        {
                            <div class="alert alert-warning mb-0" role="alert">@scoresError</div>
                        }
                        else if (examScores.Count == 0)
                        {
                            <p class="text-muted mb-0">暂无成绩记录。可在「我的成绩」页面新增，或由管理员通过 Excel 批量导入。</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm mb-0 align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>年份</th>
                                            <th>总分</th>
                                            <th>院校</th>
                                            <th>专业</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var x in examScores)
                                        {
                                            <tr>
                                                <td>@x.Year</td>
                                                <td>@x.TotalScore</td>
                                                <td>@(x.SchoolName ?? "—")</td>
                                                <td>@(x.MajorName ?? "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</RequireLogin>

@code {
    private AccountProfileDto? profile;
    private string editUserName = string.Empty;
    private string editEmail = string.Empty;

    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;

    private bool loadingProfile = true;
    private string? loadError;
    private bool savingProfile;
    private bool savingPassword;
    private string? profileMessage;
    private string? passwordMessage;
    private bool profileOk;
    private bool passwordOk;
    private string? bannerError;
    private string? bannerSuccess;
    private bool profileLoadStarted;

    private bool IsRootProfile =>
        profile is not null && string.Equals(profile.Role, "Root", StringComparison.OrdinalIgnoreCase);

    private List<ExamScoreListItemDto> examScores = new();
    private bool loadingScores;
    private string? scoresError;
    private string scoreYearText = string.Empty;
    private bool savingScore;
    private string newScoreYear = string.Empty;
    private string newScoreTotal = string.Empty;
    private string newScoreSchoolId = string.Empty;
    private string newScoreMajorId = string.Empty;
    private string? scoreMessage;
    private bool scoreMessageOk;
    private string? currentAccessToken;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || profileLoadStarted)
        {
            return;
        }

        // 等浏览器侧会话状态可用后再加载受保护数据。
        try
        {
            var token = await GetAccessTokenAsync();
            if (string.IsNullOrWhiteSpace(token))
            {
                return;
            }
        }
        catch
        {
            // JS/本地存储尚未就绪，等下一轮渲染再试
            return;
        }

        profileLoadStarted = true;
        await LoadProfileAsync();
        StateHasChanged();
    }

    private async Task LoadProfileAsync()
    {
        loadingProfile = true;
        loadError = null;
        bannerError = null;
        try
        {
            var token = await RequireAccessTokenAsync();
            profile = await AccountApi.GetMeAsync(token);
            TokenStore.SetProfile(profile.Id, profile.UserName, profile.Role);

            editUserName = profile.UserName;
            editEmail = profile.Email;

            await ReloadScoresAsync();
        }
        catch (ApiException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await ClearLocalLoginStateAsync();
            Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/account")}", forceLoad: false);
            loadingProfile = false;
            return;
        }
        catch (ApiException ex)
        {
            loadError = ex.Message;
        }
        catch
        {
            loadError = "网络错误，请稍后重试。";
        }
        finally
        {
            loadingProfile = false;
        }
    }

    private async Task SaveProfileAsync()
    {
        profileMessage = null;
        bannerSuccess = null;
        if (IsRootProfile)
        {
            profileOk = false;
            profileMessage = "Root 账号的用户名与邮箱不可修改。";
            return;
        }

        savingProfile = true;
        try
        {
            var token = await RequireAccessTokenAsync();
            var body = new UpdateAccountRequest { UserName = editUserName, Email = editEmail };
            var updated = await AccountApi.UpdateProfileAsync(body, token);
            profile = updated;
            editUserName = updated.UserName;
            editEmail = updated.Email;
            TokenStore.SetProfile(updated.Id, updated.UserName, updated.Role);

            profileOk = true;
            profileMessage = "已保存。";
            bannerSuccess = "基本资料已更新。";
        }
        catch (ApiException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await ClearLocalLoginStateAsync();
            Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/account")}", forceLoad: false);
        }
        catch (ApiException ex)
        {
            profileOk = false;
            profileMessage = ex.Message;
        }
        catch
        {
            profileOk = false;
            profileMessage = "保存时出错。";
        }
        finally
        {
            savingProfile = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        passwordMessage = null;
        bannerSuccess = null;
        if (newPassword != confirmPassword)
        {
            passwordOk = false;
            passwordMessage = "两次输入的新密码不一致。";
            return;
        }

        savingPassword = true;
        try
        {
            var token = await RequireAccessTokenAsync();
            var body = new ChangePasswordRequest { CurrentPassword = currentPassword, NewPassword = newPassword };
            await AccountApi.ChangePasswordAsync(body, token);

            passwordOk = true;
            passwordMessage = "密码已更新。";
            bannerSuccess = "密码已更新，请使用新密码登录。";
            currentPassword = string.Empty;
            newPassword = string.Empty;
            confirmPassword = string.Empty;
        }
        catch (ApiException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await ClearLocalLoginStateAsync();
            Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/account")}", forceLoad: false);
        }
        catch (ApiException ex)
        {
            passwordOk = false;
            passwordMessage = ex.Message;
        }
        catch
        {
            passwordOk = false;
            passwordMessage = "提交时出错。";
        }
        finally
        {
            savingPassword = false;
        }
    }

    private async Task ReloadScoresAsync()
    {
        if (profile is null)
        {
            return;
        }

        loadingScores = true;
        scoresError = null;
        scoreMessage = null;
        try
        {
            var token = await RequireAccessTokenAsync();
            var year = int.TryParse(scoreYearText, out var y) ? (int?)y : null;
            examScores = await ExamScoresApi.SearchAsync(profile.Id, year, null, null, token);
        }
        catch (ApiException ex)
        {
            if (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await ClearLocalLoginStateAsync();
                Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/account")}", forceLoad: false);
                return;
            }

            scoresError = ex.Message;
            examScores = new List<ExamScoreListItemDto>();
        }
        catch
        {
            scoresError = "成绩记录加载失败。";
            examScores = new List<ExamScoreListItemDto>();
        }
        finally
        {
            loadingScores = false;
        }
    }

    private async Task CreateScoreAsync()
    {
        scoreMessage = null;
        if (profile is null)
        {
            scoreMessageOk = false;
            scoreMessage = "账户信息尚未加载完成。";
            return;
        }

        if (!int.TryParse(newScoreYear, out var year) || !int.TryParse(newScoreTotal, out var total))
        {
            scoreMessageOk = false;
            scoreMessage = "请填写有效的年份和总分。";
            return;
        }

        savingScore = true;
        try
        {
            var token = await RequireAccessTokenAsync();
            var dto = new ExamScoreCreateDto
            {
                UserId = profile.Id,
                Year = year,
                TotalScore = total,
                SchoolId = int.TryParse(newScoreSchoolId, out var sid) ? (int?)sid : null,
                MajorId = int.TryParse(newScoreMajorId, out var mid) ? (int?)mid : null
            };

            await ExamScoresApi.CreateAsync(dto, token);
            scoreMessageOk = true;
            scoreMessage = "成绩已新增。";
            newScoreYear = string.Empty;
            newScoreTotal = string.Empty;
            newScoreSchoolId = string.Empty;
            newScoreMajorId = string.Empty;
            await ReloadScoresAsync();
        }
        catch (ApiException ex)
        {
            scoreMessageOk = false;
            scoreMessage = ex.Message;
        }
        catch
        {
            scoreMessageOk = false;
            scoreMessage = "新增成绩失败。";
        }
        finally
        {
            savingScore = false;
        }
    }

    private async Task ClearLocalLoginStateAsync()
    {
        try
        {
            await JS.InvokeAsync<KyInfo.Blazor.Auth.BrowserAuthResult>("kyinfoAuth.logout");
            TokenStore.Clear();
        }
        catch
        {
            // Ignore logout failures during cleanup
        }
    }

    private async Task<string?> GetAccessTokenAsync()
    {
        if (!string.IsNullOrWhiteSpace(currentAccessToken))
        {
            return currentAccessToken;
        }

        var auth = await JS.InvokeAsync<KyInfo.Blazor.Auth.BrowserAuthResult>("kyinfoAuth.getSession");
        if (auth.Session?.IsAuthenticated != true || string.IsNullOrWhiteSpace(auth.Session.Token))
        {
            currentAccessToken = null;
            return null;
        }

        currentAccessToken = auth.Session.Token;
        TokenStore.SetAuthenticated(
            auth.Session.Token,
            auth.Session.UserName,
            auth.Session.Role,
            auth.Session.UserId);
        return currentAccessToken;
    }

    private async Task<string> RequireAccessTokenAsync()
    {
        var token = await GetAccessTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            throw new ApiException(System.Net.HttpStatusCode.Unauthorized, "登录状态已失效，请重新登录后再试。");
        }

        return token;
    }
}
