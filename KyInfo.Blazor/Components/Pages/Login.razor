@page "/login"
@using Microsoft.AspNetCore.WebUtilities
@using KyInfo.Contracts.Auth
@using KyInfo.Blazor.ApiClient
@using KyInfo.Blazor.Auth

<PageTitle>用户登录 - KyInfo</PageTitle>

<div class="login-anime-page">
    <div class="login-anime-bg" aria-hidden="true">
        <span class="login-anime-float login-anime-float-1">✦</span>
        <span class="login-anime-float login-anime-float-2">♪</span>
        <span class="login-anime-float login-anime-float-3">☆</span>
        <span class="login-anime-float login-anime-float-4">✧</span>
    </div>

    <div class="login-anime-card">
        <div class="login-anime-card-header">
            <div class="login-anime-badge">KyInfo</div>
            <h1 class="login-anime-title">欢迎回来</h1>
            <p class="login-anime-sub">继续你的考研信息之旅吧 ♡</p>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert login-anime-alert login-anime-alert-success" role="alert">
                @successMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert login-anime-alert login-anime-alert-danger" role="alert">
                @errorMessage
            </div>
        }

        <EditForm Model="@loginModel" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="login-anime-validation" />

            <div class="login-anime-field mb-3">
                <label class="login-anime-label">用户名或邮箱</label>
                <InputText class="form-control login-anime-input" @bind-Value="loginModel.UserNameOrEmail" placeholder="请输入…" />
            </div>

            <div class="login-anime-field mb-4">
                <label class="login-anime-label">密码</label>
                <InputText class="form-control login-anime-input" @bind-Value="loginModel.Password" type="password" placeholder="••••••••" />
            </div>

            <div class="login-anime-actions">
                <button class="btn login-anime-btn-primary" type="submit" disabled="@isSubmitting">
                    @(isSubmitting ? "登录中…" : "登录 ✨")
                </button>
                <button class="btn login-anime-btn-ghost" type="button" @onclick="GoToRegister">
                    还没有账号？去注册 →
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private bool isSubmitting;
    private string? errorMessage;
    private string? successMessage;

    [Inject]
    private AccountApiClient AccountApi { get; set; } = default!;

    [Inject]
    private TokenStore TokenStore { get; set; } = default!;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private string? returnUrl;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("returnUrl", out var value))
        {
            returnUrl = value.ToString();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var session = await JS.InvokeAsync<BrowserAuthResult>("kyinfoAuth.getSession");
            if (session.Ok && session.Session?.IsAuthenticated == true)
            {
                if (!string.IsNullOrWhiteSpace(session.Session.Token))
                {
                    TokenStore.SetAuthenticated(
                        session.Session.Token,
                        session.Session.UserName,
                        session.Session.Role,
                        session.Session.UserId);
                }
                else if (session.Session.UserId.HasValue &&
                    !string.IsNullOrWhiteSpace(session.Session.UserName) &&
                    !string.IsNullOrWhiteSpace(session.Session.Role))
                {
                    TokenStore.SetProfile(
                        session.Session.UserId.Value,
                        session.Session.UserName,
                        session.Session.Role);
                }

                var target = string.IsNullOrWhiteSpace(returnUrl) ? "/" : returnUrl;
                try
                {
                    var me = await AccountApi.GetMeAsync(TokenStore.Token);
                    if (me is not null)
                    {
                        TokenStore.SetProfile(me.Id, me.UserName, me.Role);
                        Navigation.NavigateTo(target, forceLoad: false);
                        return;
                    }
                }
                catch (ApiException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    await ClearLocalLoginStateAsync();
                    errorMessage = "登录状态已失效，请重新登录。";
                    StateHasChanged();
                }
            }
        }
        catch
        {
            // 忽略 JS 异常
        }
    }

    private async Task ClearLocalLoginStateAsync()
    {
        try
        {
            await JS.InvokeAsync<BrowserAuthResult>("kyinfoAuth.logout");
            TokenStore.Clear();
        }
        catch
        {
            // 忽略退出清理失败
        }
    }

    private async Task HandleValidSubmit()
    {
        errorMessage = null;
        successMessage = null;
        isSubmitting = true;

        try
        {
            var auth = await JS.InvokeAsync<BrowserAuthResult>("kyinfoAuth.login", loginModel);
            if (!auth.Ok || auth.Session?.IsAuthenticated != true)
            {
                errorMessage = auth.Message ?? "登录失败，请稍后再试。";
                return;
            }

            if (!string.IsNullOrWhiteSpace(auth.Session.Token))
            {
                TokenStore.SetAuthenticated(
                    auth.Session.Token,
                    auth.Session.UserName,
                    auth.Session.Role,
                    auth.Session.UserId);
            }
            else if (auth.Session.UserId.HasValue &&
                !string.IsNullOrWhiteSpace(auth.Session.UserName) &&
                !string.IsNullOrWhiteSpace(auth.Session.Role))
            {
                TokenStore.SetProfile(
                    auth.Session.UserId.Value,
                    auth.Session.UserName,
                    auth.Session.Role);
            }

            successMessage = "登录成功，正在跳转…";

            await Task.Delay(800);
            var target = string.IsNullOrWhiteSpace(returnUrl) ? "/" : returnUrl;
            Navigation.NavigateTo(target, forceLoad: false);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch
        {
            errorMessage = "登录过程中发生错误，请稍后重试。";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo(string.IsNullOrWhiteSpace(returnUrl)
            ? "/register"
            : $"/register?returnUrl={Uri.EscapeDataString(returnUrl)}");
    }

}
