@using KyInfo.Blazor.Auth
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject TokenStore TokenStore

@if (!checkedState)
{
    <p class="text-muted">正在检查管理员权限...</p>
}
else if (!isAdmin)
{
    <div class="alert alert-warning" role="alert">
        无权访问该页面，正在跳转...
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter]
    public RenderFragment ChildContent { get; set; } = default!;

    private bool checkedState;
    private bool isAdmin;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (checkedState)
        {
            return;
        }

        try
        {
            var auth = await JS.InvokeAsync<BrowserAuthResult>("kyinfoAuth.getSession");
            if (auth.Session?.IsAuthenticated != true)
            {
                TokenStore.Clear();
                var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
                var returnUrl = "/" + relative;
                Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: false);
                checkedState = true;
                StateHasChanged();
                return;
            }

            if (!string.IsNullOrWhiteSpace(auth.Session.Token))
            {
                TokenStore.SetAuthenticated(
                    auth.Session.Token,
                    auth.Session.UserName,
                    auth.Session.Role,
                    auth.Session.UserId);
            }
            else if (auth.Session.UserId.HasValue &&
                !string.IsNullOrWhiteSpace(auth.Session.UserName) &&
                !string.IsNullOrWhiteSpace(auth.Session.Role))
            {
                TokenStore.SetProfile(
                    auth.Session.UserId.Value,
                    auth.Session.UserName,
                    auth.Session.Role);
            }

            isAdmin = AdminAreaRoles.IsStaff(auth.Session.Role);
            if (!isAdmin)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
        }
        catch
        {
            // Browser auth fetch may fail briefly during hydration; retry on next render.
            return;
        }

        checkedState = true;
        StateHasChanged();
    }
}
